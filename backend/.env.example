# ─── Server ───
PORT=3001

# ─── Admin Credentials ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ─── API Key (secondary auth layer) ───
# Rotate this key periodically. All admin requests must include
# x-api-key header with this value IN ADDITION to a valid JWT.
API_KEY=sbt-admin-key-change-me

# ─── Blockchain ───
RPC_URL=http://127.0.0.1:8545
# Private key of the deployer account (Hardhat default account #0)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
CONTRACT_ADDRESS=

# ─── IP Whitelisting (comma-separated, empty = disabled) ───
ALLOWED_IPS=

# ─── IPFS / Pinata (optional for local dev) ───
# If keys are absent, IPFS pinning is skipped and a mock hash is returned.
PINATA_API_KEY=
PINATA_SECRET=
